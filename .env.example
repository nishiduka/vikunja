# Copie para .env e ajuste os valores:
#   cp .env.example .env

# URL pública onde o Vikunja será acessado (inclua a porta se não for 80/443)
VIKUNJA_SERVICE_PUBLICURL=http://localhost:3456

# Segredo para assinar tokens JWT (use uma string longa e aleatória)
VIKUNJA_SERVICE_SECRET=altere-este-segredo-para-algo-aleatorio

# Porta exposta no host
VIKUNJA_PORT=3456

# MySQL
MYSQL_ROOT_PASSWORD=altere-a-senha-root
MYSQL_DATABASE=vikunja
MYSQL_USER=vikunja
MYSQL_PASSWORD=altere-a-senha-do-usuario
